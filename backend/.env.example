# Backend environment
PORT=4000

# Required: Supabase project URL
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Required: Service Role key (server-side only; NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used for user token verification via GoTrue endpoint
# If not set, SERVICE_ROLE_KEY is used for apikey header (fine for server environment)
SUPABASE_ANON_KEY=your-anon-key

# Optional providers (uncomment and set to enable real notifications)
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
